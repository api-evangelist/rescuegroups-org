        {
          "info": {
            "name": "Get Public Organization",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://api.rescuegroups.org/v5/public/orgs/:org_id",
            "params": [
              {
                "name": "org_id",
                "value": "",
                "type": "path",
                "description": "The unique organization identifier."
              }
            ]
          },
          "docs": "Retrieve a single public rescue organization by ID."
        }
