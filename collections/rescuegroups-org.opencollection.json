              {
                "name": "limit",
                "value": "",
                "type": "query",
                "description": "Number of records per page (max 250)."
              }
            ]
          },
          "docs": "Retrieve all animal breed reference values."
        }
      ]
    },
    {
      "info": {
        "name": "Species",
        "type": "folder"
      },
      "items": [
        {
          "info": {
